<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting (Android 12+) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:statusBarColor">@color/deep_navy</item>
        <item name="android:navigationBarColor">@color/deep_navy</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <!-- NormalTheme -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/deep_navy</item>
        <item name="android:statusBarColor">@color/deep_navy</item>
        <item name="android:navigationBarColor">@color/deep_navy</item>
    </style>
</resources>
